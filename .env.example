# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Site role: set SITE_ROLE=admin on the admin Netlify site (storefront site: leave unset)
# NEXT_PUBLIC_SITE_MODE=admin

# App URL (storefront — used in emails and links)
NEXT_PUBLIC_APP_URL=https://your-storefront-domain.com

# Admin portal URL (set on storefront site to redirect /admin-portal to the separate admin site)
# NEXT_PUBLIC_ADMIN_URL=https://your-admin-site.netlify.app

# API URL — where /api/* routes live
# Local dev: leave empty (same origin)
# Admin Netlify site: set to your storefront Netlify URL, e.g. https://royaale-luxe.netlify.app
# Storefront Netlify site: leave empty (serves its own API)
# NEXT_PUBLIC_API_URL=https://your-storefront.netlify.app

# Comma-separated browser origins allowed to call the API (set on the site that serves /api/*)
# Must include the admin Netlify URL when using a separate admin site.
# ALLOWED_ORIGINS=https://your-storefront-domain.com,https://your-admin-site.netlify.app

# Firebase Admin SDK (required for server API routes)
# FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Transactional email
# Order confirmations & cancellations — Gmail SMTP (from royaaleluxe@gmail.com)
# 1. Enable 2-Step Verification on the Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# GMAIL_USER=royaaleluxe@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_FROM_EMAIL=Royaale Luxe <royaaleluxe@gmail.com>

# Back-in-stock alerts via Resend (https://resend.com) — optional
# RESEND_DOMAIN=yourdomain.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Royaale Luxe <orders@yourdomain.com>
# RESEND_TEST_TO=you@email.com

# Sign-up verification & password reset — Firebase Authentication (Firebase Console → Authentication → Templates)
# Customize sender name and templates there; links redirect to /account after verification.

# Admin notifications
# ADMIN_ALERT_EMAIL=royaaleluxe@gmail.com
# ADMIN_ORDER_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# WEBHOOK_SECRET=your-shared-secret-for-webhook-verification

# Telegram admin notifications (https://core.telegram.org/bots)
# 1. Message @BotFather to create a bot and get the token
# 2. Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_ADMIN_CHAT_ID=your_chat_id
