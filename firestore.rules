rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userNotDisabled() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('disabled', false) != true;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Orders are created server-side via Admin SDK (POST /api/orders/create)
      allow create: if false;
      allow list: if isAdmin();
      allow get: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{uid} {
      allow list: if isAdmin();
      allow get: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isAdmin()
        || (isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['disabled', 'adminNotes']));
    }

    match /admins/{uid} {
      allow list: if isAdmin();
      allow get: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /districtFees/{feeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow create, update: if isAdmin();
    }

    match /newsletter/{subscriberId} {
      // Subscriptions via POST /api/newsletter/subscribe (rate-limited, deduped)
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /promos/{promoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /adminAlerts/{alertId} {
      // Alerts created server-side only
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }
  }
}
